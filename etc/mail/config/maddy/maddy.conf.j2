# Maddy Relay SMTP configuration file
# Start with: docker run --network=host -v {{ content_dir }}/email/maddy:/data --name maddy-email-relay --restart unless-stopped -d flowlogix/maddy

$(primary_domain) = {{ mail_forwarder_primary_domain }}
$(local_relay_target) = {{ mail_forwarder_transport_destination }}
$(local_domains) = $(primary_domain) {{ mail_forwarder_relay_domains | join(' ') }}
$(default_max_message_size) = {{ mail_forwarder_message_size_limit }}
$(hostname) = smtp.$(primary_domain)

hostname $(hostname)
tls off

msgpipeline local_routing {
    destination $(local_domains) {
        deliver_to lmtp tcp://$(local_relay_target)
    }

    default_destination {
        reject 550 5.1.1 "User doesn't exist"
    }
}

target.queue local_queue {
    target &local_routing
    location /data/queue
    max_parallelism 16
    max_tries 999999
    autogenerated_msg_domain $(primary_domain)
    debug no
}

smtp tcp://0.0.0.0:25 {
    limits {
        # Up to 20 msgs/sec across max. 10 SMTP connections.
        all rate 20 1s
        all concurrency 10
    }
    max_message_size $(default_max_message_size)
    dmarc no

    source $(local_domains) {
        reject 501 5.1.8 "Use Submission for outgoing SMTP"
    }

    default_source {
        destination postmaster $(local_domains) {
            deliver_to &local_queue
        }

        default_destination {
            reject 550 5.1.1 "User doesn't exist"
        }
    }
}
